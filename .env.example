# Copy to .env and fill in.
CARTESIA_API_KEY=sk_car_xxx
# Single defined female voice for NOA (pick one from your Cartesia voice library).
NOA_VOICE_ID=00000000-0000-0000-0000-000000000000
# Claude key for NOA's reasoning brain (the agent + mock tools).
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Login gate ──
# Credentials checked against the login form input.
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
# Secret that signs the session cookie. Use a long random string in production
# (e.g. `openssl rand -base64 32`). Rotating it invalidates all sessions.
SESSION_SECRET=replace-with-long-random-string

# ── Telephony bridge (server/phone.ts, Fly.io) ──
# Only CARTESIA_API_KEY / NOA_VOICE_ID / ANTHROPIC_API_KEY are needed here — the
# phone path has no login gate, so the AUTH_*/SESSION_SECRET above are web-only.
# Port the WebSocket server listens on (Fly sets this; defaults to 8080 locally).
PORT=8080
# Optional: set to validate X-Twilio-Signature on the /incoming-call webhook.
TWILIO_AUTH_TOKEN=
