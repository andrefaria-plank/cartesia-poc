{
  "name": "cartesia-voice-mode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NOA Voice Mode — turn-based voice agent (Ink STT + Sonic TTS) over SSE + base64",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "pnpm": ">=10",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "tsx watch src/server.ts",
    "bench": "tsx src/benchmark.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@cartesia/cartesia-js": "^2.2.9",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.2.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
