{
  "name": "cartesia-voice-mode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NOA Voice Mode — turn-based voice agent (Ink STT + Sonic TTS) over SSE + base64",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "bench": "tsx src/benchmark.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cartesia/cartesia-js": "^2.2.9",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
